---
import BaseLayout from '../layouts/BaseLayout.astro';
import BlackholeScene from '../components/BlackholeScene.astro';
import { getPublishedBlogEntries } from '../data/blog';
import { getFriendPlanets } from '../data/friends';
import { profile } from '../data/site';

const pageTitle = profile.name;
const projectsModule = await import('../../public/projects.json');
const projects = projectsModule.default as { name: string; href: string }[];
const friends = await getFriendPlanets();
const latestPosts = (await getPublishedBlogEntries()).slice(0, 5);

const aboutParagraphs = [
  '你好，我是洛柠 Naloveyuki，一名高中生，也是一位长期把文档、项目和表达当回事的人。',
  '我喜欢写文档、学习编程语言和计算机知识，也会把这些理解慢慢沉淀成页面、文章和可继续展开的作品。',
  '平时我也会和朋友一起玩 Minecraft，折腾工具，参与公开组织里的协作，并继续把复杂内容整理得更清楚。',
];
---

<BaseLayout
  title={pageTitle}
  description={profile.description}
  pathname="/"
  bodyClass="theme-blackhole"
  showFooter={false}
  blackholeMode="home"
  friendPlanets={friends}
>
  <BlackholeScene
    scene="home"
    storyId="about"
    riskLines={['可能会引起光敏性癫痫症状发作', '如有不适请尽快停止滚动或离开页面']}
  >
    <div class="blackhole-story-intro">
      <p class="blackhole-kicker">Next</p>
      <h2>更多内容正在整理中</h2>
    </div>

    <div class="blackhole-home-sections">
      <article class="blackhole-placeholder">
        <span>About</span>
        <h3>关于我</h3>
        {aboutParagraphs.map((paragraph) => <p>{paragraph}</p>)}
      </article>

      <article class="blackhole-placeholder">
        <span>Projects</span>
        <h3>项目与作品</h3>
        <ul class="blackhole-link-list" aria-label="项目与作品链接">
          {
            projects.map((project) => (
              <li>
                <a class="blackhole-list-link" href={project.href} target="_blank" rel="noreferrer">
                  {project.name}
                </a>
              </li>
            ))
          }
        </ul>
      </article>

      <article class="blackhole-placeholder">
        <span>Writing</span>
        <h3>文章与记录</h3>
        {
          latestPosts.length > 0 ? (
            <ul class="blackhole-link-list" aria-label="最近文章链接">
              {latestPosts.map((post) => (
                <li>
                  <a class="blackhole-list-link" href={`/blog/${post.id}/`}>
                    {post.data.title}
                  </a>
                </li>
              ))}
            </ul>
          ) : (
            <p>最近文章会展示在这里。</p>
          )
        }
      </article>

      <article class="blackhole-placeholder blackhole-friends-panel">
        <span>Friends</span>
        <h3>友联星系</h3>
        <p>每一个友联都会成为环绕黑洞运行的一颗星球，性格类型决定它的地貌与温度。</p>
        <ul class="blackhole-friend-list" aria-label="友联列表">
          {
            friends.map((friend) => (
              <li>
                <a class="blackhole-list-link" href={friend.url} target="_blank" rel="noreferrer">
                  {friend.name}
                </a>
                <small>{friend.type}</small>
              </li>
            ))
          }
        </ul>
      </article>
    </div>
  </BlackholeScene>
</BaseLayout>
