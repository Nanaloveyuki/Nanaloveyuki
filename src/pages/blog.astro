---
import BaseLayout from '../layouts/BaseLayout.astro';
import { formatBlogDate, getPublishedBlogEntries } from '../data/blog';
import { profile } from '../data/site';

const pageTitle = `${profile.name} | 文章与记录`;
const posts = await getPublishedBlogEntries();
---

<BaseLayout
  title={pageTitle}
  description="这里收录了我的文章、笔记和持续更新的记录。"
  pathname="/blog"
  bodyClass="theme-blackhole theme-stars"
  showFooter={false}
  blackholeMode="orbit"
>
  <main class="stars-page shell" data-blackhole-page data-blackhole-scene="blog">
    <section class="stars-hero page-heading">
      <p class="eyebrow">Writing</p>
      <h1>文章与记录</h1>
    </section>

    <section class="stars-post-list" aria-label="文章列表">
      {
        posts.length > 0 ? (
          posts.map((post) => (
            <article class="stars-post-item">
              <p class="stars-post-meta">{formatBlogDate(post.data.time)}</p>
              <h2>
                <a class="stars-post-link" href={`/blog/${post.id}/`}>
                  {post.data.title}
                </a>
              </h2>
              {post.data.tags.length > 0 && (
                <ul class="stars-tag-list" aria-label={`${post.data.title} 标签`}>
                  {post.data.tags.map((tag) => (
                    <li>{tag}</li>
                  ))}
                </ul>
              )}
              {post.data.des && <p class="stars-post-summary">{post.data.des}</p>}
            </article>
          ))
        ) : (
          <article class="stars-post-item">
            <p class="stars-post-meta">No Entries</p>
            <h2>还没有公开文章</h2>
          </article>
        )
      }
    </section>
  </main>
</BaseLayout>
