---
import BlackholeScene from '@blackhole/BlackholeScene.astro';
import { projects } from '@data/projects';
import { profile } from '@data/site';
import BaseLayout from '@/layouts/BaseLayout.astro';

const pageTitle = `${profile.name} | 项目展示`;
---

<BaseLayout
  title={pageTitle}
  description="这里展示我正在做或已经公开的一些项目。"
  pathname="/projects"
  bodyClass="theme-blackhole"
  showFooter={false}
  blackholeMode="orbit"
>
  <BlackholeScene scene="projects" storyClass="blackhole-story-page">
    <div class="blackhole-story-intro blackhole-story-intro-page">
      <p class="blackhole-kicker">Projects</p>
      <h1>项目</h1>
      <p>公开展示的项目、正在投入的方向，以及我愿意继续做深的作品都会放在这里。</p>
    </div>

    <div class="blackhole-entry-list" aria-label="项目列表">
      {
        projects.map((project) => (
          <article class="blackhole-entry" data-project-slug={project.slug}>
            <p class="blackhole-entry-meta">{project.featured ? 'Featured Project' : 'Project'}</p>
            <h2>
              <a class="blackhole-title-link" href={project.href} target="_blank" rel="noreferrer">
                {project.name}
              </a>
            </h2>
            <p class="blackhole-entry-tagline">{project.tagline}</p>
            <ul class="blackhole-tag-list" aria-label={`${project.name} 标签`}>
              {project.tags.map((tag) => (
                <li>{tag}</li>
              ))}
            </ul>
            <p>{project.summary}</p>
            <p class="blackhole-entry-stack">{project.stack.join(' / ')}</p>
            <a class="blackhole-inline-link" href={project.href} target="_blank" rel="noreferrer">
              查看仓库
            </a>
          </article>
        ))
      }
    </div>
  </BlackholeScene>
</BaseLayout>
