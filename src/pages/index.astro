---
import BaseLayout from '../layouts/BaseLayout.astro';
import { profile } from '../data/site';

const pageTitle = profile.name;

const placeholderSections = [
  {
    label: 'About',
    title: '关于我',
    description: '这里将补充更完整的个人介绍、身份说明和正在关注的方向。',
  },
  {
    label: 'Projects',
    title: '项目与作品',
    description: '这里将整理公开项目、长期在做的内容，以及值得继续展开的作品。',
  },
  {
    label: 'Writing',
    title: '文章与记录',
    description: '这里会逐步补充博客、笔记和持续更新的文字入口。',
  },
] as const;
---

<BaseLayout
  title={pageTitle}
  description={profile.description}
  pathname="/"
  bodyClass="theme-blackhole"
  showFooter={false}
>
  <main class="blackhole-page" data-blackhole-demo>
    <div class="blackhole-background" aria-hidden="true">
      <div class="blackhole-canvas" data-blackhole-canvas></div>
      <div class="blackhole-vignette"></div>
    </div>

    <section class="blackhole-scroll-track" data-blackhole-scroll-track aria-hidden="true">
    </section>

    <div class="blackhole-risk-note" aria-hidden="true" data-blackhole-risk-note>
      <p>可能会引起光敏性癫痫症状发作</p>
      <p>如有不适请尽快回到首页</p>
    </div>

    <section id="about" class="blackhole-story shell" data-blackhole-story>
      <div class="blackhole-story-intro">
        <p class="blackhole-kicker">Next</p>
        <h2>更多内容正在整理中</h2>
        <p>下方先保留内容结构和位置，后续会逐步替换成正式信息。</p>
      </div>

      <div class="blackhole-placeholder-list">
        {
          placeholderSections.map((section) => (
            <article class="blackhole-placeholder">
              <span>{section.label}</span>
              <h3>{section.title}</h3>
              <p>{section.description}</p>
            </article>
          ))
        }
      </div>
    </section>
  </main>

  <script>
    import '../scripts/blackhole-demo.ts';
  </script>
</BaseLayout>
