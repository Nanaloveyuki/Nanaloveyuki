---
import BaseLayout from '../layouts/BaseLayout.astro';
import { aboutSections, profile, quickFacts, skills, timeline } from '../data/site';

const pageTitle = `${profile.name} | 关于我`;
---

<BaseLayout title={pageTitle} description={profile.description} pathname="/about">
  <main class="shell">
    <section class="panel reveal">
      <div class="page-heading">
        <p class="eyebrow">About</p>
        <h1>关于我</h1>
        <p>{profile.summary}</p>
      </div>

      <div class="content-grid">
        {
          aboutSections.map((section) => (
            <article class="content-card">
              <h2>{section.title}</h2>
              <ul class="prose-list">
                {section.content.map((item) => (
                  <li>{item}</li>
                ))}
              </ul>

              {section.links && (
                <div class="action-row">
                  {section.links.map((link) => (
                    <a
                      class="button button-secondary"
                      href={link.href}
                      target={link.external ? '_blank' : undefined}
                      rel={link.external ? 'noreferrer' : undefined}
                    >
                      {link.label}
                    </a>
                  ))}
                </div>
              )}
            </article>
          ))
        }
      </div>
    </section>

    <section class="panel reveal delay-1">
      <div class="section-heading">
        <div>
          <p class="eyebrow">Snapshot</p>
          <h2>技能和基础信息</h2>
        </div>
        <p>这里把比较稳定的基础信息和能力方向集中整理出来。</p>
      </div>

      <div class="section-grid">
        <article class="content-card">
          <h2>基本信息</h2>
          <ul class="prose-list">
            {
              quickFacts.map((fact) => (
                <li>
                  {fact.label}：{fact.value}
                </li>
              ))
            }
          </ul>
        </article>

        <article class="content-card">
          <h2>技能快照</h2>
          <ul class="pill-list">
            {skills.map((skill) => <li>{skill}</li>)}
          </ul>
        </article>
      </div>
    </section>

    <section class="panel reveal delay-2">
      <div class="section-heading">
        <div>
          <p class="eyebrow">Timeline</p>
          <h2>成长轨迹</h2>
        </div>
        <p>用几段简短的时间线，说明我这些年持续在做什么。</p>
      </div>

      <div class="timeline-grid">
        {
          timeline.map((item) => (
            <article class="timeline-card">
              <span class="meta-label">{item.period}</span>
              <h3>{item.title}</h3>
              <p>{item.description}</p>
            </article>
          ))
        }
      </div>
    </section>
  </main>
</BaseLayout>
