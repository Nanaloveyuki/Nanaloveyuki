{
  "name": "nanaloveyuki-pages",
  "private": true,
  "type": "module",
  "version": "0.1.0",
  "packageManager": "pnpm@11.5.3",
  "engines": {
    "node": ">=22.12.0 <26"
  },
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro:check": "astro check",
    "lint": "eslint .",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "deps:unused": "knip --production",
    "deps:outdated": "pnpm outdated",
    "deps:audit": "pnpm audit --audit-level moderate",
    "check": "pnpm lint && pnpm astro:check && pnpm format:check && pnpm deps:unused",
    "ci": "pnpm check && pnpm build"
  },
  "dependencies": {
    "@fontsource/fraunces": "^5.2.8",
    "@fontsource/noto-sans-sc": "^5.2.8",
    "astro": "^6.4.7",
    "three": "^0.185.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@eslint/js": "^9.30.1",
    "@types/three": "^0.185.0",
    "eslint": "^9.30.1",
    "eslint-plugin-astro": "^1.3.1",
    "globals": "^16.3.0",
    "knip": "^5.63.1",
    "prettier": "^3.6.2",
    "prettier-plugin-astro": "^0.14.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.35.1"
  },
  "knip": {
    "entry": [
      "src/pages/**/*.astro",
      "src/styles/global.css"
    ],
    "ignoreDependencies": [
      "@fontsource/fraunces",
      "@fontsource/noto-sans-sc",
      "three"
    ],
    "project": [
      "src/**/*.{astro,ts,css}",
      "astro.config.mjs",
      "eslint.config.mjs",
      "prettier.config.mjs"
    ]
  }
}
