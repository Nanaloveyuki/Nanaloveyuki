---
import { ClientRouter } from 'astro:transitions';
import '@fontsource/fraunces/700.css';
import '@fontsource/noto-sans-sc/400.css';
import '@fontsource/noto-sans-sc/500.css';
import '@fontsource/noto-sans-sc/700.css';
import '../styles/global.css';
import { navLinks, profile, socialLinks } from '../data/site';

type Props = {
  title: string;
  description: string;
  pathname?: string;
  bodyClass?: string;
  showFooter?: boolean;
};

const { title, description, pathname = '/', bodyClass = '', showFooter = true } = Astro.props;
const basePath = import.meta.env.BASE_URL;
const assetBase = basePath.endsWith('/') ? basePath : `${basePath}/`;
const useBlackholeShell = bodyClass.split(' ').includes('theme-blackhole');
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href={`${assetBase}favicon.svg`} />
    <link rel="icon" href={`${assetBase}favicon.ico`} />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <title>{title}</title>
    <ClientRouter />
  </head>

  <body class={bodyClass} data-route-pathname={pathname}>
    {
      useBlackholeShell && (
        <>
          <div class="blackhole-global" data-blackhole-root transition:persist>
            <div class="blackhole-canvas" data-blackhole-canvas />
            <div class="blackhole-vignette" />
          </div>

          <div
            class="blackhole-night-warning"
            data-blackhole-night-warning
            role="dialog"
            aria-modal="true"
            aria-labelledby="blackhole-night-warning-title"
            aria-describedby="blackhole-night-warning-copy"
            hidden
          >
            <div class="blackhole-night-warning-backdrop" data-blackhole-night-warning-dismiss />
            <div class="blackhole-night-warning-card shell">
              <p class="blackhole-night-warning-kicker">Night Notice</p>
              <h2 id="blackhole-night-warning-title">夜间提醒</h2>
              <p id="blackhole-night-warning-copy">
                由于渲染黑洞会导致光差十分明显, 为了您的眼部健康, 不推荐在少光无光的情况下进入
              </p>
              <button
                type="button"
                class="blackhole-night-warning-action"
                data-blackhole-night-warning-confirm
              >
                我已知晓
              </button>
            </div>
          </div>

          <div class="blackhole-friend-tooltip" data-blackhole-friend-tooltip hidden>
            <p class="blackhole-friend-tooltip-type" data-blackhole-friend-tooltip-type />
            <h3 class="blackhole-friend-tooltip-name" data-blackhole-friend-tooltip-name />
            <p
              class="blackhole-friend-tooltip-description"
              data-blackhole-friend-tooltip-description
            />
          </div>

          <aside class="blackhole-planet-panel" data-blackhole-planet-panel hidden>
            <div class="blackhole-planet-panel-card shell">
              <div class="blackhole-planet-panel-header">
                <div>
                  <p class="blackhole-planet-panel-type" data-blackhole-planet-panel-type />
                  <h3 class="blackhole-planet-panel-name" data-blackhole-planet-panel-name />
                </div>
                <button
                  type="button"
                  class="blackhole-planet-panel-close"
                  data-blackhole-planet-panel-close
                  aria-label="关闭星球概览"
                >
                  ×
                </button>
              </div>

              <div class="blackhole-planet-panel-preview" data-blackhole-planet-panel-preview>
                <div class="blackhole-planet-panel-preview-orbit" aria-hidden="true">
                  <div
                    class="blackhole-planet-panel-preview-atmosphere"
                    data-blackhole-planet-panel-preview-atmosphere
                  >
                    <div
                      class="blackhole-planet-panel-preview-clouds"
                      data-blackhole-planet-panel-preview-clouds
                    />
                    <div
                      class="blackhole-planet-panel-preview-planet"
                      data-blackhole-planet-panel-preview-planet
                    >
                      <div
                        class="blackhole-planet-panel-preview-water"
                        data-blackhole-planet-panel-preview-water
                      />
                      <div
                        class="blackhole-planet-panel-preview-land"
                        data-blackhole-planet-panel-preview-land
                      />
                      <div
                        class="blackhole-planet-panel-preview-equator"
                        data-blackhole-planet-panel-preview-equator
                      />
                      <div
                        class="blackhole-planet-panel-preview-pole is-north"
                        data-blackhole-planet-panel-preview-pole-north
                      />
                      <div
                        class="blackhole-planet-panel-preview-pole is-south"
                        data-blackhole-planet-panel-preview-pole-south
                      />
                    </div>
                    <div
                      class="blackhole-planet-panel-preview-ring"
                      data-blackhole-planet-panel-preview-ring
                    />
                  </div>
                </div>
                <p data-blackhole-planet-panel-preview-copy>Planet Overview</p>
              </div>

              <p
                class="blackhole-planet-panel-description"
                data-blackhole-planet-panel-description
              />

              <dl class="blackhole-planet-panel-stats">
                <div>
                  <dt>性格类型</dt>
                  <dd data-blackhole-planet-panel-stat-type />
                </div>
                <div>
                  <dt>半径</dt>
                  <dd data-blackhole-planet-panel-stat-radius />
                </div>
                <div>
                  <dt>温度</dt>
                  <dd data-blackhole-planet-panel-stat-temperature />
                </div>
                <div>
                  <dt>大气</dt>
                  <dd data-blackhole-planet-panel-stat-atmosphere />
                </div>
                <div>
                  <dt>轨道</dt>
                  <dd data-blackhole-planet-panel-stat-orbit />
                </div>
                <div>
                  <dt>质量</dt>
                  <dd data-blackhole-planet-panel-stat-weight />
                </div>
                <div>
                  <dt>自转</dt>
                  <dd data-blackhole-planet-panel-stat-rotation />
                </div>
                <div>
                  <dt>自倾角</dt>
                  <dd data-blackhole-planet-panel-stat-tilt />
                </div>
                <div>
                  <dt>极地</dt>
                  <dd data-blackhole-planet-panel-stat-poles />
                </div>
                <div>
                  <dt>赤道</dt>
                  <dd data-blackhole-planet-panel-stat-equator />
                </div>
                <div>
                  <dt>云层</dt>
                  <dd data-blackhole-planet-panel-stat-clouds />
                </div>
                <div>
                  <dt>地表</dt>
                  <dd data-blackhole-planet-panel-stat-surface />
                </div>
              </dl>

              <a
                class="blackhole-planet-panel-link"
                data-blackhole-planet-panel-link
                href="#"
                target="_blank"
                rel="noopener noreferrer"
              >
                访问友链
              </a>
            </div>
          </aside>
        </>
      )
    }

    <header class="site-header" data-site-header>
      <div class="shell site-header-inner">
        <a class="site-brand" href={assetBase}>
          <span>
            <strong>{profile.name}</strong>
            <small>Personal Pages</small>
          </span>
        </a>

        <nav aria-label="主导航">
          <ul class="site-nav">
            {
              navLinks.map((item) => {
                const isActive = pathname === item.href;

                return (
                  <li>
                    <a
                      class:list={{ 'is-active': isActive }}
                      href={item.href}
                      target={item.external ? '_blank' : undefined}
                      rel={item.external ? 'noreferrer' : undefined}
                    >
                      {item.label}
                    </a>
                  </li>
                );
              })
            }
          </ul>
        </nav>
      </div>
    </header>

    <slot />

    {
      showFooter && (
        <footer class="site-footer">
          <div class="shell site-footer-inner">
            <div>
              <p class="footer-title">{profile.name}</p>
              <p class="footer-copy">{profile.summary}</p>
            </div>

            <ul class="footer-links">
              {socialLinks.map((item) => (
                <li>
                  <a
                    href={item.href}
                    target={item.external ? '_blank' : undefined}
                    rel={item.external ? 'noreferrer' : undefined}
                  >
                    {item.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        </footer>
      )
    }

    {
      useBlackholeShell && (
        <>
          <script define:vars={{ assetBase }} is:inline>
            window.__BLACKHOLE_ASSET_BASE__ = assetBase;
          </script>

          <script>import '../scripts/blackhole-demo.ts';</script>
        </>
      )
    }
  </body>
</html>
